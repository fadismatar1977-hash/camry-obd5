<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07080d">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HV Battery Pack"
                    android:textSize="15sp"
                    android:textColor="#e8e8f0"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14 Cells · Camry Hybrid 2014"
                    android:textSize="11sp"
                    android:textColor="#8888a0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/btn_share_log"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="📤"
                    android:textSize="14sp"
                    android:background="@drawable/badge_bg"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/btn_toggle_log"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="🔴 REC"
                    android:textSize="11sp"
                    android:textColor="#ff3355"
                    android:background="@drawable/badge_bg"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/pack_health_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="● GOOD"
                    android:textSize="11sp"
                    android:textColor="#00ff88"
                    android:background="@drawable/badge_bg"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0e1018"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CELL VOLTAGES"
                android:textSize="10sp"
                android:textColor="#8888a0"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="7"
                android:rowCount="2">

                <TextView android:id="@+id/cell1" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell2" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell3" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell4" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell5" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell6" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell7" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell8" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell9" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell10" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell11" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell12" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell13" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/cell14" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_columnWeight="1" android:layout_margin="2dp" android:gravity="center"
                    android:background="#0a1a0e" android:textColor="#00ff88" android:textSize="10sp"
                    android:textStyle="bold" />
            </GridLayout>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/battery_chart"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:background="#080a10"
                android:padding="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/pack_max_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="14sp"
                        android:textColor="#00ff88" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Max V" android:textSize="9sp" android:textColor="#8888a0" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/pack_min_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="14sp"
                        android:textColor="#ff3355" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Min V" android:textSize="9sp" android:textColor="#8888a0" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/pack_delta_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="14sp"
                        android:textColor="#ffd600" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Δ mV" android:textSize="9sp" android:textColor="#8888a0" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/pack_avg_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="14sp"
                        android:textColor="#00d2ff" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg V" android:textSize="9sp" android:textColor="#8888a0" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/pack_total_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="14sp"
                        android:textColor="#e8e8f0" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total V" android:textSize="9sp" android:textColor="#8888a0" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0e1018"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCE ANALYSIS"
                android:textSize="10sp"
                android:textColor="#8888a0"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />
            <TextView
                android:id="@+id/balance_analysis_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect to see battery balance status."
                android:textSize="13sp"
                android:textColor="#8888a0"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
